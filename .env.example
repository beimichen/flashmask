# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# Loaded by flashmask.data.scrape via pydantic-settings.

# CORE API key — https://core.ac.uk/services/api  (free key on request)
FLASHMASK_CORE_API_KEY=

# Contact email required by NCBI Entrez (PMC) per their usage policy.
FLASHMASK_ENTREZ_EMAIL=you@example.com
